    "clsx": "^2.1.1",
    "framer-motion": "^12.23.9",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-intersection-observer": "^9.16.0",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^3.3.1",
    "three": "^0.152.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
